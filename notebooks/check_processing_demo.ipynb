   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Bank Check Processing Demonstration",
    "This notebook demonstrates the complete workflow for check processing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Import required modules",
    "import sys",
    "sys.path.append('..')",
    "",
    "from src.preprocessing import CheckPreprocessor",
    "from src.ocr_extraction import CheckProcessor",
    "from src.check_validator import CheckValidator",
    "from src.annotation_utils import LabelStudioAnnotator",
    "",
    "# Initialize processors",
    "preprocessor = CheckPreprocessor(debug=True)",
    "ocr_processor = CheckProcessor()",
    "validator = CheckValidator()",
    "annotator = LabelStudioAnnotator()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Load and preprocess a check image",
    "image_path = '../data/raw_checks/sample_check.jpg'",
    "preprocessed_image = preprocessor.preprocess_image(image_path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Extract text using different OCR methods",
    "easyocr_results = ocr_processor.extract_text_easyocr(preprocessed_image)",
    "tesseract_results = ocr_processor.extract_text_tesseract(preprocessed_image)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Validate extracted information",
    "amount_valid, amount_message = validator.validate_amount(",
    "    easyocr_results['amounts'][0],",
    "    tesseract_results['amounts'][0]",
    ")",
    "",
    "print(\"Amount Validation:\", amount_valid, amount_message)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Create annotation project",
    "project = annotator.create_project(",
    "    'sample_check.jpg',",
    "    '../data/preprocessed/preprocessed_sample_check.jpg'",
    ")"
   ]
  }
 ],
